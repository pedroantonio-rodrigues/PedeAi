DATABASE_URL="postgresql://usuario:senha@localhost:5432/pedeai"

JWT_SECRET="defina-um-segredo-forte-e-aleatorio"

PORT=3000

# Origem permitida para CORS (opcional; padrao "*" libera todas)
CORS_ORIGIN="*"

# Seed do primeiro usuario ADMIN (npm run db:seed)
# ADMIN_SENHA e obrigatoria; as demais tem valores padrao.
ADMIN_NOME="Administrador"
ADMIN_EMAIL="admin@pedeai.com"
ADMIN_SENHA="defina-uma-senha-forte"
ADMIN_CPF="00000000000"
ADMIN_TELEFONE="00000000000"
ADMIN_ENDERECO="Nao informado"
